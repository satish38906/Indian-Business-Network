{
  "info": {
    "name": "Member Management API",
    "description": "Complete API collection for testing member management",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "chapterId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "memberId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Member Management",
      "item": [
        {
          "name": "Add Member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"business_name\": \"Tech Solutions Inc\",\n  \"business_category\": \"Technology\",\n  \"contact\": \"+1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/members/{{chapterId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{chapterId}}"]
            }
          }
        },
        {
          "name": "Get Chapter Members",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/members/{{chapterId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{chapterId}}"]
            }
          }
        },
        {
          "name": "Get My Member Data",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/members/me/data",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "me", "data"]
            }
          }
        },
        {
          "name": "Get Member by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/members/detail/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "detail", "{{memberId}}"]
            }
          }
        },
        {
          "name": "Update Member",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"business_name\": \"Updated Tech Solutions\",\n  \"business_category\": \"Technology\",\n  \"contact\": \"+1234567890\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/members/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{memberId}}"]
            }
          }
        },
        {
          "name": "Update Member Status to Inactive",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/members/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{memberId}}"]
            }
          }
        },
        {
          "name": "Update Member Image",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/members/{{memberId}}/image",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{memberId}}", "image"]
            }
          }
        },
        {
          "name": "Delete Member",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/members/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{memberId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Test Cases",
      "item": [
        {
          "name": "Test - Duplicate Category (Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"business_name\": \"Another Tech Company\",\n  \"business_category\": \"Technology\",\n  \"contact\": \"+9876543210\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/members/{{chapterId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{chapterId}}"]
            }
          }
        },
        {
          "name": "Test - Missing Business Name (Should Fail)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"business_category\": \"Technology\",\n  \"contact\": \"+1234567890\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/members/{{chapterId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{chapterId}}"]
            }
          }
        },
        {
          "name": "Test - Invalid Status (Should Fail)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"invalid_status\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/members/{{memberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "members", "{{memberId}}"]
            }
          }
        }
      ]
    }
  ]
}
