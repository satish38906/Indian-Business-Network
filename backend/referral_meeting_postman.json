            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/referrals/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "referrals", "1"]
            }
          }
        },
        {
          "name": "Update Referral Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
