{
  "info": {
    "name": "Referral & Meeting Management API",
    "description": "Complete API collection for BNI-style referral system and meeting management",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Referrals",
      "item": [
        {
          "name": "Create Referral",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"to_member_id\": 2,\n  \"chapter_id\": 1,\n  \"meeting_id\": 1,\n  \"business_name\": \"ABC Corporation\",\n  \"contact_name\": \"John Doe\",\n  \"contact_phone\": \"+1234567890\",\n  \"referral_value\": 5000.00,\n  \"notes\": \"Web development project\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/referrals",
              "host": ["{{baseUrl}}"],
              "path": ["api", "referrals"]
            }
          }
        },
        {
          "name": "Get My Referrals",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
